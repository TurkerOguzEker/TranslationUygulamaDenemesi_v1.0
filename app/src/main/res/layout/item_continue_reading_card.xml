<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Kitap Kapağı -->
        <ImageView
            android:id="@+id/imgContinueCover"
            android:layout_width="64dp"
            android:layout_height="88dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            android:background="#E0E0E0"
            android:layout_marginEnd="14dp"/>

        <!-- Bilgi Alanı -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OKUMAYA DEVAM ET"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtContinueTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kitap Adı"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txtContinueAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Yazar"
                android:textSize="12sp"
                android:textColor="#757575"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pbContinueProgressHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    app:indicatorColor="#FF9800"
                    app:trackColor="#E0E0E0"
                    app:trackThickness="6dp"
                    app:trackCornerRadius="3dp" />

                <TextView
                    android:id="@+id/tvContinueProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="%0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />
            </LinearLayout>

        </LinearLayout>

        <!-- Ok ikonu -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="#BDBDBD" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
